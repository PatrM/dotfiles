{
    "$schema": "https://opencode.ai/config.json",
    "formatter": false,
    "mcp": {
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        },
        "filesystem-user": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/Users/patrick/"
            ],
            "enabled": true
        },
        "filesystem-tmp": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/tmp/"
            ],
            "enabled": true
        },
        "atlassian": {
            "type": "remote",
            "url": "https://mcp.atlassian.com/v1/mcp",
            "enabled": true
        },
        "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
            "enabled": true
    },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },
        "google-calendar": {
            "type": "remote",
            "url": "https://calendarmcp.googleapis.com/mcp/v1",
            "enabled": true
        },
        "java": {
            "type": "local",
            "command": [
                "jdtls",
                "--java-executable",
                "$HOME/.sdkman/candidates/java/21.0.9-amzn/bin/java"
            ],
            "enabled": true
        },
        "kotlin": {
            "type": "local",
            "command": [
                "kotlin-lsp"
            ],
            "enabled": true
        },
        "tredict": {
            "type": "remote",
            "url": "https://www.tredict.com/api/mcp/v2",
            "oauth": false,
            "headers": {
                "Authorization": "Bearer {env:TREDICT_PERSONAL_API_KEY}"
            },
            "enabled": true
        },
        "grafana": {
            "type": "local",
            "command": [
                "uvx",
                "mcp-grafana"
            ],
            "environment": {
                "GRAFANA_URL": "https://grafana.prd.minubo.com/",
                "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
            },
            "enabled": true
        },
        "awslabs.cloudwatch-mcp-server": {
            "type": "local",
            "command": [
                "uvx",
                "awslabs.cloudwatch-mcp-server@latest"
            ],
            "environment": {
                "AWS_PROFILE": "default",
                "FASTMCP_LOG_LEVEL": "ERROR"
            },
            "enabled": true
        },
        "metabase": {
            "type": "remote",
            "url": "https://metabase.minubo.com/api/mcp",
            "enabled": true
        },
        "qmd": {
            "type": "local",
            "command": [
                "qmd",
                "mcp"
            ],
            "enabled": true
        }
    },
    "permission": {
        "skill": {
            "*": "allow"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    }
}
